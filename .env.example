# Copy to .env.local and fill in.

# Database. Local dev: turso dev --db-file dev.db serves on :8080.
# Use 127.0.0.1 (not localhost) — Node's fetch resolves "localhost" to ::1 first
# and turso dev only binds IPv4. Prod: libsql://<db>-<org>.turso.io
DATABASE_URL=http://127.0.0.1:8080
DATABASE_AUTH_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth — register at github.com/settings/developers
# Callback URL (dev): http://localhost:3000/api/auth/callback/github
# Required scope: user:email
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stars feature — used as the salt for anonymous IP+UA identity hashing.
# Generate with: openssl rand -hex 32
STARS_IDENTITY_SECRET=

# OpenRouter — free models at openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free,nvidia/nemotron-3-super-120b-a12b:free,nvidia/nemotron-3-nano-30b-a3b:free,z-ai/glm-4.5-air:free
